@model IReadOnlyList<Estudiantes_MVC.Models.EstudianteViewModel>

@{
    ViewData["Title"] = "Estudiantes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Estudiantes registrados</h1>
        <p class="text-muted mb-0">Consumo MVC del API de estudiantes.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nuevo estudiante</a>
</div>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}

@if (ViewData["ApiError"] is string apiError)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">El API no está disponible.</div>
        <div>@apiError</div>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">No hay estudiantes registrados.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estudiante in Model)
                        {
                            <tr>
                                <td>@estudiante.Id</td>
                                <td>@estudiante.Nombre</td>
                                <td>@estudiante.Email</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@estudiante.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                                    <a asp-action="Edit" asp-route-id="@estudiante.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@estudiante.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
